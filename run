#!/usr/bin/env bash
# vim:ft=bash

# auto export
set -o allexport 

# ⚠️ 强制 shell 环境为 bash，保证后续脚本 100% 🆗 
SHELL=bash

# nvim envs
NVIM_HOME="$(readlink -f "$0" | xargs dirname)"
NVIM_APPNAME="pretty.nvim"
NVIM_EXECUTABLE="$NVIM_HOME/prebuilts/nvim"

# 添加本地可执行文件到 PATH
# 💡 优先级：prebuilts > node_modules > py3env > 系统
PATH="$NVIM_HOME/py3env/bin:$PATH"
PATH="$NVIM_HOME/node_modules/.bin:$PATH"
PATH="$NVIM_HOME/prebuilts/bin:$PATH"

# 💡 启动环境 - :h startup for details
: "${XDG_CONFIG_HOME:=$HOME/.config}"

mkdir -p "$XDG_CONFIG_HOME"
test -L "$XDG_CONFIG_HOME/$NVIM_APPNAME" || ln -sf "$NVIM_HOME" "$XDG_CONFIG_HOME/$NVIM_APPNAME"

# 解决 clang-tidy 找不到标准头文件的问题
if test -z "$CPATH"; then
    which xcrun &>/dev/null && CPATH="$(xcrun --show-sdk-path)/usr/include" || CPATH="/usr/include"
fi

set +o allexport 

# 💡 启动 virtualenv
source "$NVIM_HOME/py3env/bin/activate"

case "$1" in
    --update-plugins)
        exec "$NVIM_EXECUTABLE" --headless -c 'packloadall | silent! helptags ALL | UpdateRemotePlugins' +quit
        ;;
    --update*)
        cd "$NVIM_HOME" && exec ./install.sh "$@"
        ;;
    --help|-h)
        "$NVIM_EXECUTABLE" --help

        cat <<EOF

---
Extend Options:
    --update                update $NVIM_APPNAME
    --update-core           update nvim binaries
    --update-plugins        update plugins' cache
EOF
        exit
        ;;
esac

if test -n "$NVIM_REMOTE_SOCKET"; then
    # 💡 start nvim inside nvim
    exec "$NVIM_EXECUTABLE" "$@"
else
    # ⚠️ nvim 默认使用 NVIM / NVIM_LISTEN_ADDRESS (deprecated) for listen addr
    export NVIM_REMOTE_SOCKET="/tmp/nvim-$$.sock"
    # 💡 listen on sock, required by nopen.sh|lazygit
    exec "$NVIM_EXECUTABLE" --listen "$NVIM_REMOTE_SOCKET" "$@"
fi
