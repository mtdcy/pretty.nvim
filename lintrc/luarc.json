{
  "$schema": "LuaLS/vscode-lua",
  "runtime.version": "LuaJIT",
  "runtime.path": [
    "lua/?.lua",
    "lua/?/init.lua"
  ],
  "workspace": {
    "maxPreload": 1000,
    "preloadFileSize": 150,
    "useGitIgnore": true,
    "ignoreDir": [
      ".git",
      "node_modules",
      "py3env",
      "prebuilts"
    ],
    "library": [
      "$VIMRUNTIME/lua"
    ]
  },
  "log-path": "/tmp/luals.log",
  "diagnostics": {
    "enable": true,
    "globals": [
      "vim",
      "describe",
      "it",
      "before_each",
      "after_each",
      "pending"
    ],
    "disable": [
      "lowercase-global",
      "undefined-global",
      "redundant-parameter",
      "param-type-mismatch",
      "assign-type-mismatch",
      "unused-local",
      "unused-vararg"
    ],
    "severity": {
      "await": "Warning",
      "codestyle-check": "Information",
      "code-after-break": "Warning",
      "empty-block": "Information",
      "redundant-return": "Warning",
      "redundant-return-value": "Warning",
      "return-type-mismatch": "Error",
      "trailing-space": "Information",
      "unreachable-code": "Warning"
    },
    "group_file_strategy": "folder"
  },
  "completion": {
    "enable": true,
    "callSnippet": "Replace",
    "keywordSnippet": "Disable",
    "displayContext": 10,
    "autoRequire": true
  },
  "hover": {
    "enable": true,
    "viewNumber": true,
    "viewString": true,
    "viewStringMax": 1000
  },
  "signatureHelp": {
    "enable": true
  },
  "telemetry": {
    "enable": false
  },
  "format": {
    "enable": true
  },
  "codeLens": {
    "enable": true
  },
  "semantic": {
    "enable": true
  },
  "hint": {
    "enable": true,
    "setType": false,
    "paramName": "All",
    "paramType": true,
    "arrayIndex": "Enable"
  }
}
